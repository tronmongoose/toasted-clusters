# Toasted Clusters configuration. Copy to `.env` and edit.

# Where transcripts are written. Defaults to ~/vault if unset.
OBSIDIAN_VAULT=~/vault

# Subdirectory under OBSIDIAN_VAULT for meeting transcripts.
OBSIDIAN_MEETINGS_SUBDIR=meetings

# Whisper MLX model. "large-v3" is the highest quality, slowest, ~3GB on first download.
# Alternatives: "medium", "small", "tiny" (faster, lower quality).
# distil-* variants are smaller; check lightning-whisper-mlx docs for availability.
WHISPER_MODEL=large-v3

# "local" (default, Whisper MLX on this machine) or "cloud" (Deepgram).
TRANSCRIBER_MODE=local

# Only needed if TRANSCRIBER_MODE=cloud. Leave empty for local mode.
DEEPGRAM_API_KEY=
